	 	 				 map1.put("ORD_ID", ORD_ID);
	 	 				 map1.put("MALL_ID", MALL_ID);
	 					
	 					
	 					orderDAO.UptTrans(map1);
					}
					
					
				}
				
			}
			
		}catch (Exception e) {
